+// Utility functions for formatting common data types
+
+/**
+ * Formats distance in meters to kilometers with appropriate precision.
+ * @param {number | null | undefined} meters - Distance in meters.
+ * @returns {string} - Formatted distance string (e.g., "10.23 km", "5.1 km") or 'N/A'.
+ */
+export function formatDistance(meters) {
+  if (meters === null || meters === undefined || meters < 0) return 'N/A'
+  const kilometers = meters / 1000
+  const precision = kilometers < 10 ? 2 : 1
+  // Use Intl.NumberFormat for locale-aware number formatting if needed in the future
+  return `${kilometers.toFixed(precision)} km`
+}
+
+/**
+ * Formats duration in seconds to a human-readable string (e.g., "1h 30m 15s", "45m 0s").
+ * @param {number | null | undefined} seconds - Duration in seconds.
+ * @returns {string} - Formatted duration string or 'N/A'.
+ */
+export function formatDuration(seconds) {
+  if (seconds === null || seconds === undefined || seconds < 0) return 'N/A'
+  if (seconds === 0) return '0s'
+
+  const h = Math.floor(seconds / 3600)
+  const m = Math.floor((seconds % 3600) / 60)
+  const s = Math.floor(seconds % 60)
+  let result = ''
+  if (h > 0) result += `${h}h `
+  if (m > 0 || h > 0) result += `${m}m ` // Show minutes if hours exist or if minutes > 0
+  result += `${s}s`
+  return result.trim()
+}
+
+/**
+ * Formats elevation gain in meters.
+ * @param {number | null | undefined} meters - Elevation gain in meters.
+ * @returns {string} - Formatted elevation string (e.g., "1,234 m") or 'N/A'.
+ */
+export function formatElevation(meters) {
+  if (meters === null || meters === undefined) return 'N/A'
+  // Use toLocaleString for thousands separators based on locale
+  return `${Math.round(meters).toLocaleString()} m`
+}
+
+/**
+ * Formats calories.
+ * @param {number | null | undefined} calories - Calories.
+ * @returns {string} - Formatted calories string (e.g., "1,500 kcal") or 'N/A'.
+ */
+export function formatCalories(calories) {
+  if (calories === null || calories === undefined || calories <= 0) return 'N/A'
+  // Use toLocaleString for thousands separators based on locale
+  return `${Math.round(calories).toLocaleString()} kcal`
+}
+
+/**
+ * Formats pace from seconds per meter to minutes per kilometer.
+ * @param {number | null | undefined} pace - Pace in seconds per meter.
+ * @returns {string} - Formatted pace string (e.g., "5:30 /km") or 'N/A'.
+ */
+export function formatPace(pace) {
+  if (pace === null || pace === undefined || pace <= 0) return 'N/A'
+
+  // Convert seconds/meter to seconds/kilometer
+  const paceSecondsPerKm = pace * 1000
+
+  const minutes = Math.floor(paceSecondsPerKm / 60)
+  const seconds = Math.round(paceSecondsPerKm % 60)
+  return `${minutes}:${seconds.toString().padStart(2, '0')} /km`
+}
+
+/**
+ * Formats average heart rate.
+ * @param {number | null | undefined} avgHr - Average heart rate in bpm.
+ * @returns {string} - Formatted heart rate string (e.g., "150 bpm") or 'N/A'.
+ */
+export function formatAvgHr(avgHr) {
+  if (avgHr === null || avgHr === undefined || avgHr <= 0) return 'N/A'
+  return `${Math.round(avgHr)} bpm`
+}
+
+/**
+ * Formats a date/time string into a locale-aware, user-friendly format.
+ * @param {string | null | undefined} dateTimeString - ISO 8601 date-time string.
+ * @returns {string} - Formatted date/time string or 'N/A'.
+ */
+export function formatDateTime(dateTimeString) {
+  if (!dateTimeString) return 'N/A'
+  try {
+    const options = {
+      year: 'numeric',
+      month: 'short',
+      day: 'numeric',
+      hour: '2-digit',
+      minute: '2-digit'
+      // timeZoneName: 'short' // Optional: Add timezone abbreviation
+    }
+    // Use local timezone formatting by default
+    return new Date(dateTimeString).toLocaleString(undefined, options)
+  } catch (e) {
+    console.error('Error formatting date:', e)
+    return dateTimeString // Fallback
+  }
+}
